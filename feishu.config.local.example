# 复制为 feishu.config.local（不会提交 Git），再运行 bash scripts/setup-github-feishu-secrets.sh

# 部署通知用 — OpenClaw「我的小龙虾」
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx

# OpenClaw 主应用（智能助手，供其他集成备用，部署通知默认不用）
FEISHU_OPENCLAW_APP_ID=cli_xxxxxxxx
FEISHU_OPENCLAW_APP_SECRET=xxxxxxxx

# 接收人（三选一，无邮箱时用 open_id）
# FEISHU_RECEIVE_EMAIL=your@company.com
# FEISHU_RECEIVE_ID=ou_xxxxxxxx   ← 无邮箱时用这个
